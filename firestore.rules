rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsShop(shopId) {
      return signedIn() && request.auth.uid == shopId;
    }

    match /shops/{shopId} {
      allow read, create, update: if ownsShop(shopId);
      allow delete: if false;

      match /inventory_items/{itemId} {
        allow read, create, update, delete: if ownsShop(shopId);
      }

      match /credits/{creditId} {
        allow read, create, update, delete: if ownsShop(shopId);
      }

      match /transactions/{transactionId} {
        allow read, create, update, delete: if ownsShop(shopId);
      }

      match /voice_commands/{commandId} {
        allow read, create, update: if ownsShop(shopId);
        allow delete: if false;
      }
    }
  }
}
